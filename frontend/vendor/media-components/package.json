{
  "name": "@flatstone/media-components",
  "version": "0.1.4",
  "description": "Shared media components for FLATSTONE projects (video player, preview, thumbnails)",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
